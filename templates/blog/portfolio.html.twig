<script>
    function showDocument(docId) {
        // Rendre invisible tous les documents
        document.querySelectorAll('.pdf-container').forEach(doc => {
            doc.classList.remove('active');
        });

        // Afficher uniquement le document sélectionné
        const selectedDoc = document.getElementById(docId);
        if (selectedDoc) {
            selectedDoc.classList.add('active');
        }
    }

    // Afficher le premier document par défaut au chargement
    window.onload = function() {
        showDocument('doc1');
    };
</script>
